# LEDSAS service identity
KBM_LEDSAS_SERVICE_NAME=HeartRateFitnessAge
KBM_LEDSAS_TENANT=demo

# Mode: 'direct' — the SDK talks to RabbitMQ + Azure Blob directly.
KBM_LEDSAS_MODE=direct

# Connection settings.
# Defaults match the bundled docker-compose.yml from the LEDSAS SDK
# direct-mode distribution (3-local-development/). Replace with your own
# production credentials before deploying. NOTE the connection strings are
# QUOTED — they contain ';' which a shell would otherwise split on.
KBM_LEDSAS_RABBITMQ_URL="amqp://guest:guest@127.0.0.1:5672/"
KBM_LEDSAS_BLOB_CONN_STRING="DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;"

# Default blob container for outputs
KBM_LEDSAS_CONTAINER=heart-rate-fitness-age

# Concurrency / prefetch
KBM_LEDSAS_PREFETCH=10
KBM_LEDSAS_CONCURRENCY=4

# Logging
KBM_LEDSAS_LOG_LEVEL=INFO
KBM_LEDSAS_LOG_FORMAT=json

# Health probe binding (defaults shown). For Kubyk pod deployments where the
# orchestrator probes from outside the container network namespace, bind
# 0.0.0.0 instead of 127.0.0.1.
KBM_LEDSAS_HEALTH_HOST=127.0.0.1
KBM_LEDSAS_HEALTH_PORT=8090
